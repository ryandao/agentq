# Database (Prisma)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=agentq
DB_SCHEMA=public

# Redis
AGENTQ_REDIS_URL=redis://localhost:6379/0

# Task queue
AGENTQ_TASK_QUEUE_SYSTEM=celery        # or "none" to disable worker inspection
AGENTQ_DEFAULT_QUEUE_NAME=celery
AGENTQ_CELERY_CONTROL_EXCHANGE=celery
AGENTQ_CELERY_INSPECT_TIMEOUT_MS=1000

# Auth
AGENTQ_SERVER_ADMIN_USERNAME=admin
AGENTQ_SERVER_ADMIN_PASSWORD=changeme
AGENTQ_INGEST_API_KEY=                 # optional: restrict SDK ingestion

# LLM (for AI-powered features like session titles and search)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
