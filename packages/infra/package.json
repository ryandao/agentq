{
    "name": "@agentq/infra",
    "version": "0.1.0",
    "description": "Infrastructure monitoring types, hooks, and UI for AgentQ",
    "license": "MIT",
    "author": "Ryan Dao",
    "repository": {
        "type": "git",
        "url": "https://github.com/ryandao/agentq.git",
        "directory": "packages/infra"
    },
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./client": {
            "types": "./src/client/index.ts",
            "default": "./src/client/index.ts"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "react": "^18",
        "@subframe/core": "^1"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": false
        },
        "@subframe/core": {
            "optional": false
        }
    },
    "devDependencies": {
        "typescript": "^5"
    }
}
