{
  "name": "@agentq/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentQ — auto-detect and integrate with popular agent frameworks",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.mjs",
      "require": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentq",
    "ai",
    "agents",
    "langchain",
    "crewai",
    "autogen",
    "llamaindex",
    "sdk",
    "typescript"
  ],
  "author": "DevSquad",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "langchain": ">=0.1.0",
    "@langchain/core": ">=0.1.0",
    "crewai": ">=0.1.0",
    "autogen": ">=0.1.0",
    "llamaindex": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "langchain": { "optional": true },
    "@langchain/core": { "optional": true },
    "crewai": { "optional": true },
    "autogen": { "optional": true },
    "llamaindex": { "optional": true }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
